<core:FragmentDefinition
  xmlns:core="sap.ui.core"
  xmlns="sap.m"
  xmlns:f="sap.ui.layout.form">
  <Dialog id="registerDialog" title="Register dataspace partner" contentWidth="32rem">
    <content>
      <f:SimpleForm editable="true" layout="ResponsiveGridLayout" labelSpanXL="4" labelSpanL="4">
        <f:content>
          <Label text="DID / BPN"/>
          <Input value="{register>/did}" placeholder="e.g. BPNL000000000ACME"/>
          <Label text="Name"/>
          <Input value="{register>/name}"/>
          <Label text="Role"/>
          <Select selectedKey="{register>/role}">
            <core:Item key="recycler" text="Recycler"/>
            <core:Item key="authority" text="Authority"/>
          </Select>
          <Label text="Login secret"/>
          <Input value="{register>/secret}" type="Password"/>
        </f:content>
      </f:SimpleForm>
    </content>
    <beginButton>
      <Button text="Register" type="Emphasized" press="onRegisterSave"/>
    </beginButton>
    <endButton>
      <Button text="Cancel" press="onRegisterCancel"/>
    </endButton>
  </Dialog>
</core:FragmentDefinition>
