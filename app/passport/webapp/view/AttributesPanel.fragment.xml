<core:FragmentDefinition xmlns="sap.m" xmlns:core="sap.ui.core">
  <!-- Guide-format passport attributes (DIN DKE SPEC 99100 longlist). Rows are
       tier-filtered server-side, so each tier view shows exactly the
       attributes its audience may see. -->
  <Panel headerText="Passport attributes (DIN DKE SPEC 99100)" expandable="true" expanded="false"
         class="sapUiSmallMarginTop">
    <!-- accessClass must be part of the $select: the server fails closed and
         drops rows it cannot classify. -->
    <Table items="{ path: 'attributes', sorter: { path: 'section' }, parameters: { $select: 'accessClass' } }"
           noDataText="No passport attributes.">
      <columns>
        <Column width="22%" demandPopin="true" minScreenWidth="Tablet"><Text text="Section"/></Column>
        <Column width="38%"><Text text="Attribute"/></Column>
        <Column><Text text="Value"/></Column>
      </columns>
      <ColumnListItem>
        <cells>
          <Text text="{section}"/>
          <Text text="{attribute}"/>
          <Text text="{ path: 'valueJson', formatter: '.formatAttrValue' }"/>
        </cells>
      </ColumnListItem>
    </Table>
  </Panel>
</core:FragmentDefinition>
