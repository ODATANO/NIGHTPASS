# NIGHTPASS public demo config. Copy to deploy/.env and fill in.
# The instance is READ-ONLY toward the chain: it verifies anchors live but
# holds no wallet secrets and cannot anchor or prove. DPP_API stays off.

# Your public domain (A record must point at the server BEFORE first start,
# Caddy needs it for the Let's Encrypt handshake).
DEMO_DOMAIN=passport.example.org

# Printed into new passports' QR urls and shown in the viewer.
PASSPORT_DEMO_HOST=https://passport.example.org

# Midnight preview endpoints + the CURRENT vault (deployed 2026-07-17).
NIGHTGATE_NETWORK=preview
NIGHTGATE_INDEXER_HTTP_URL=https://indexer.preview.midnight.network/api/v4/graphql
PASSPORT_CONTRACT_ADDRESS=f7c755235cc9408bc6664f7cae88b445798726ccdf9a6a560e7c873c807aabe1

# Payload decryption key of the shipped demo DB (same value as the local .env
# ENCRYPTION_KEY, otherwise the disclosure() flows cannot open the ciphers).
ENCRYPTION_KEY=

# Demo logins for the protected tiers (public host = strong passwords).
DEMO_PASS_PRODUCER=
DEMO_PASS_AUTHORITY=
DEMO_PASS_RECYCLER=

# Public read surface only: explorer + viewer + QR resolver + anonymous
# read/verify API. Producer cockpit, writes and the DPP test API stay off.
# Remove this line if you want the full viewer surface incl. tier logins.
# PASSPORT_PUBLIC_SURFACE=explorer
