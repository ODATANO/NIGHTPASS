# "Try it" demo instance config. Copy to deploy/.env.demo and fill in.
# UNLIKE the main instance this one HOLDS A WALLET SECRET (the dedicated fee
# sponsor) and anchors visitor passports on preview. Keep the sponsor wallet
# small and dedicated: if it is ever abused, rotate it without touching
# anything else. See docs/try-it-demo-plan.md.

# Midnight preview endpoints + the CURRENT vault.
NIGHTGATE_NETWORK=preview
NIGHTGATE_INDEXER_HTTP_URL=https://indexer.preview.midnight.network/api/v4/graphql
PASSPORT_CONTRACT_ADDRESS=f7c755235cc9408bc6664f7cae88b445798726ccdf9a6a560e7c873c807aabe1

# Proof server inside the compose network (service name, never the host).
NIGHTGATE_PROOF_SERVER_URL=http://proof-server:6300

# Payload encryption key (demo instance encrypts its own visitor passports;
# a fresh strong value is fine, it does NOT need to match the main instance).
ENCRYPTION_KEY=

# The dedicated DEMO SPONSOR wallet (surfaces as server wallet id 'default').
# Values come from secrets/producer-wallets.env DEMO_SPONSOR_* on the dev
# machine. NEVER the Main wallet's secrets.
PRODUCER_WALLET_MNEMONIC=
PRODUCER_VIEWING_KEY=
PRODUCER_SHIELDED_ADDRESS=
PRODUCER_LABEL=Demo sponsor

# Fee sponsoring: the sponsor pays every visitor tx; fresh visitor wallets
# skip their (pointless) chain sync entirely.
PASSPORT_FEE_SPONSOR_WALLET=default
NIGHTGATE_SPONSORED_CALLER_SYNC=skip
NIGHTGATE_SIGNING_KEY_RATE_LIMIT=1000

# Demo surface + service switches.
DEMO_ENABLED=true
PASSPORT_PUBLIC_SURFACE=demo
# Behind Caddy: resolve the visitor IP from X-Forwarded-For, otherwise every
# visitor shares one per-IP cap bucket.
PASSPORT_TRUST_PROXY=true
# DEMO_MAX_PER_DAY=50
# DEMO_MAX_PER_IP_PER_DAY=3
# DEMO_MAX_PER_TESTER=1
# DEMO_MAX_QUEUE=5

# Publish finished visitor passports into the MAIN explorer (zkpassport.eu).
# Same secret the main instance's ingest expects (PASSPORT_INGEST_SECRET).
PASSPORT_PUBLISH_URL=https://zkpassport.eu
PASSPORT_PUBLISH_SECRET=

# Shown in QR urls of demo passports.
PASSPORT_DEMO_HOST=https://zkpassport.eu
