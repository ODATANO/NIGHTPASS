# NIGHTPASS env template. Copy to .env (gitignored) and fill in.

# 32-byte hex AES key for the off-chain payload cipher (dev tolerates a default).
# Generate: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
ENCRYPTION_KEY=

# Midnight network. The ws indexer URL is derived from the HTTP URL (NIGHTGATE 0.7.1).
NIGHTGATE_NETWORK=preview
NIGHTGATE_NODE_URL=wss://rpc.preview.midnight.network/
NIGHTGATE_INDEXER_HTTP_URL=https://indexer.preview.midnight.network/api/v4/graphql
NIGHTGATE_CRAWLER_ENABLED=false

# Deployed attestation vault. Must match the network:
# preview=dcd297ba6a335a5d64916a6f2e36151c7490baa119fd022c846944918d9cde69
# preprod=b44b9c706c829d774003bee28fa2abf4089a78fc02e5cb2aa897d7de5ea31300
PASSPORT_CONTRACT_ADDRESS=

# Wallet secrets, only needed for live on-chain anchoring. NEVER commit real values.
LACE_MNEMONIC=
LACE_VIEWING_KEY=

# Legacy single server wallet (cockpit id "default", used by the ERP ingest path).
# Multi-wallet setup: npm run start:wallets loads secrets/producer-wallets.env.
PRODUCER_WALLET_MNEMONIC=
PRODUCER_VIEWING_KEY=

# Public deploy options (demo user passwords, explorer federation, verify peers,
# PASSPORT_PUBLIC_SURFACE, PASSPORT_DEMO_HOST): see docs/public-demo.md
