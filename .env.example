# NIGHTPASS environment template. Copy to .env (gitignored) and fill in.
#   cp .env.example .env

# REQUIRED. 32-byte hex AES key used to encrypt the off-chain passport payload.
# In dev (NODE_ENV != production) a default is tolerated; set a real key in prod.
# Generate one with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
ENCRYPTION_KEY=

# Public host the QR landing URL is built against (defaults to the request host).
# PASSPORT_DEMO_HOST=https://your-demo-host

# Deployed attestation-vault address; required for on-chain anchoring and used
# as the passport rows' contractAddress (verifyOnChain checks against it).
# PASSPORT_CONTRACT_ADDRESS=

# Peer NIGHTPASS instances verifying OTHER networks (docs/public-demo.md).
# verifyOnChain delegates cross-network detail checks to them server-side.
# Server-to-server addresses. Format: net=baseUrl[,...].
# PASSPORT_VERIFY_PEERS=preprod=http://localhost:4005

# BROWSER-facing explorer URLs of the sibling per-network instances. Rendered
# as network switch links in the explorer header (one instance = one network).
# PASSPORT_EXPLORER_LINKS=preprod=http://localhost:4005/explorer/

# --- Public explorer instance (docs/public-demo.md) ---------------------------
# PASSPORT_PUBLIC_SURFACE=explorer  reduces this instance to the public
# explorer: only /explorer, GET /api/v1/passport, /qr, /p, /resolve are served
# (QR scans land on the explorer detail page); everything else 404s.
# PASSPORT_PUBLIC_SURFACE=explorer

# Producer instances this PUBLIC explorer aggregates (name=baseUrl,...): their
# anonymous anchorExplorer() surface is pulled into the local DB periodically.
# PASSPORT_SOURCES=cellco=http://localhost:4004
# PASSPORT_SYNC_INTERVAL_MS=60000

# Where "Open in Passport Viewer" points (internal work instance). Unset on a
# pure explorer surface = link hidden; unset elsewhere = same-origin.
# PASSPORT_VIEWER_BASE=https://work.demo.example

# --- Public demo hardening (docs/public-demo.md) ------------------------------
# The built-in demo users log in with password = user name by default. On a
# PUBLIC host set strong secrets here, otherwise every visitor can log in as
# authority/producer and read all tiers.
# DEMO_PASS_PRODUCER=
# DEMO_PASS_AUTHORITY=
# DEMO_PASS_RECYCLER=

# --- On-chain live run (optional) -------------------------------------------
# Only needed to anchor passports on Midnight via the NIGHTGATE plugin (the
# generatePassport sessionId path). The read-side and offline path need none of
# these. The network/crawler are also configured in package.json cds.requires.nightgate.
NIGHTGATE_NETWORK=preprod
NIGHTGATE_NODE_URL=wss://rpc.preprod.midnight.network/
NIGHTGATE_INDEXER_HTTP_URL=https://indexer.preprod.midnight.network/api/v4/graphql
NIGHTGATE_INDEXER_WS_URL=wss://indexer.preprod.midnight.network/api/v4/graphql/ws
NIGHTGATE_CRAWLER_ENABLED=false

# --- Wallet secrets (optional, live run only) -------------------------------
# Required only for the deferred on-chain wallet run. NEVER commit real values;
# .env is gitignored. Leave blank unless you are doing a live submission.
LACE_MNEMONIC=
LACE_VIEWING_KEY=
LACE_SEED_HEX=

# --- Server wallets for the producer cockpit ---------------------------------
# The cockpit login offers two signing modes: the browser's Lace wallet, or one
# of these SERVER wallets (NIGHTGATE holds the key and signs). Each is an
# independent Midnight account, so a demo can show N producers anchoring under
# their own identity. `walletId` on the on-chain actions selects one.
#
# Ids of the configured wallets, plus per-wallet secrets/identity:
# PRODUCER_WALLETS=A,B,C
# PRODUCER_A_WALLET_MNEMONIC="word1 word2 ..."   # signing key (never served)
# PRODUCER_A_VIEWING_KEY=...                     # session key (never served)
# PRODUCER_A_SHIELDED_ADDRESS=mn_shield-addr_... # identity = passport `owner`
# PRODUCER_A_LABEL=CellCo GmbH                   # optional display name
#
# In dev, `npm run start:wallets` loads all of this from the gitignored
# secrets/producer-wallets.env (written by the wallet generator) and derives
# PRODUCER_WALLETS from the ids it finds.
#
# The legacy single-wallet config below stays supported and shows up as the
# wallet id `default` (the ERP ingest path uses it when no walletId is given).
PRODUCER_WALLET_MNEMONIC=
PRODUCER_VIEWING_KEY=
# PRODUCER_SHIELDED_ADDRESS=
# PRODUCER_LABEL=Main wallet
