# NIGHTPASS environment template. Copy to .env (gitignored) and fill in.
#   cp .env.example .env

# REQUIRED. 32-byte hex AES key used to encrypt the off-chain passport payload.
# In dev (NODE_ENV != production) a default is tolerated; set a real key in prod.
# Generate one with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
ENCRYPTION_KEY=

# Public host the QR landing URL is built against (defaults to the request host).
# PASSPORT_DEMO_HOST=https://your-demo-host

# --- On-chain live run (optional) -------------------------------------------
# Only needed to anchor passports on Midnight via the NIGHTGATE plugin (the
# generatePassport sessionId path). The read-side and offline path need none of
# these. The network/crawler are also configured in package.json cds.requires.nightgate.
NIGHTGATE_NETWORK=preprod
NIGHTGATE_NODE_URL=wss://rpc.preprod.midnight.network/
NIGHTGATE_INDEXER_HTTP_URL=https://indexer.preprod.midnight.network/api/v4/graphql
NIGHTGATE_INDEXER_WS_URL=wss://indexer.preprod.midnight.network/api/v4/graphql/ws
NIGHTGATE_CRAWLER_ENABLED=false

# --- Wallet secrets (optional, live run only) -------------------------------
# Required only for the deferred on-chain wallet run. NEVER commit real values;
# .env is gitignored. Leave blank unless you are doing a live submission.
LACE_MNEMONIC=
LACE_VIEWING_KEY=
LACE_SEED_HEX=
