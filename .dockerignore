# Never bake secrets or local state into the image.
.env
.env.*
!.env.example

node_modules
.git

# Local databases stay out by default: db/passport.db can contain wallet sync
# state (midnight_WalletSyncStates) from live runs. Provide a prepared DB via a
# volume instead, or consciously remove these lines to bake one in
# (docs/public-demo.md explains how to sanitize it first).
db/*.db
db/*.db-journal
db/*.db-wal
db/*.db-shm

# Regenerated by postinstall inside the image.
@cds-models
app/connector/dist

# Not needed at runtime.
test/screenshots
docs
*.tgz
