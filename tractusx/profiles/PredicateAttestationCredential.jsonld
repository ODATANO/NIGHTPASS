{
  "@context": {
    "@version": 1.1,
    "schema": "https://schema.org/",
    "aac-aspect": "https://raw.githubusercontent.com/eclipse-tractusx/tractusx-profiles/refs/heads/main/tx/credentials/schema/context/aac/v1/AttributeAttestationCredential.jsonld#",
    "pac-aspect": "https://raw.githubusercontent.com/eclipse-tractusx/tractusx-profiles/refs/heads/main/tx/credentials/schema/context/pac/v1/PredicateAttestationCredential.jsonld#",
    "PredicateAttestationCredential": {
      "@id": "pac-aspect:PredicateAttestationCredential",
      "@type": "@id"
    },
    "attributes": {
      "@id": "aac-aspect:attributes",
      "@container": "@list",
      "@context": {
        "@version": 1.1,
        "@definition": "Mandatory: Array of attributes (path in `id`, `.`-separated). Extends AAC with a third disclosure mode: `zkPredicate`.",
        "id": "@id",
        "type": "@type",
        "digestMultibase": {
          "@id": "aac-aspect:digestMultibase",
          "@type": "schema:string",
          "@context": {
            "@definition": "Optional under indexer-trust: on-chain `persistentCommit(value, salt)` the proof is bound to. Not recomputable off-chain (Midnight `PureCircuits` is empty), so present only when the issuer resolved it from chain; otherwise omitted. The binding is enforced in-circuit regardless."
          }
        },
        "unit": {
          "@id": "aac-aspect:unit",
          "@type": "schema:string",
          "@context": {
            "@definition": "Optional: unit of the attested attribute."
          }
        },
        "disclosureMode": {
          "@id": "pac-aspect:disclosureMode",
          "@type": "schema:string",
          "@context": {
            "@definition": "Mandatory for PAC: disclosure mode. AAC defines `revealedValue` (full) and `hiddenAttributes` (opaque). PAC adds `zkPredicate`: prove a predicate over the hidden value without revealing it."
          }
        },
        "claim": {
          "@id": "pac-aspect:claim",
          "@context": {
            "@version": 1.1,
            "@definition": "Mandatory for `zkPredicate`: the predicate proven over the hidden value.",
            "predicate": {
              "@id": "pac-aspect:predicate",
              "@type": "schema:string",
              "@context": {
                "@definition": "Mandatory: predicate operator. Phase 1: `lessOrEqual`, `greaterOrEqual`, `range`."
              }
            },
            "threshold": {
              "@id": "pac-aspect:threshold",
              "@type": "schema:Number",
              "@context": {
                "@definition": "Mandatory: public bound the hidden value is proven against. For `range`, use `lowerBound`/`upperBound` instead."
              }
            },
            "lowerBound": {
              "@id": "pac-aspect:lowerBound",
              "@type": "schema:Number",
              "@context": { "@definition": "Optional: lower bound for `range`." }
            },
            "upperBound": {
              "@id": "pac-aspect:upperBound",
              "@type": "schema:Number",
              "@context": { "@definition": "Optional: upper bound for `range`." }
            },
            "unit": {
              "@id": "pac-aspect:unit",
              "@type": "schema:string",
              "@context": { "@definition": "Optional: unit of the threshold/bounds." }
            }
          }
        },
        "proof": {
          "@id": "pac-aspect:attributeProof",
          "@context": {
            "@version": 1.1,
            "@definition": "Mandatory for `zkPredicate`: the zero-knowledge proof attesting the claim. Distinct from the outer VC `proof` (issuer signature). Verification model is indexer-trust (Path 1): the proof is a submitted `provePredicate` transaction and a verifier confirms via the Midnight indexer that it was included and resolved to SUCCESS.",
            "system": {
              "@id": "pac-aspect:system",
              "@type": "schema:string",
              "@context": { "@definition": "Mandatory: proof system identifier. Indexer-trust: `midnight-compact`. Selects the verification routine; a future standalone-VK (Path 2) system would use a different id." }
            },
            "circuit": {
              "@id": "pac-aspect:circuit",
              "@type": "schema:string",
              "@context": { "@definition": "Mandatory: circuit name, e.g. `provePredicate`." }
            },
            "verificationMethod": {
              "@id": "pac-aspect:verificationMethod",
              "@type": "schema:string",
              "@context": { "@definition": "Mandatory: verification anchor. Indexer-trust: the AttestationVault CONTRACT ADDRESS whose SUCCESSful inclusion of `proofValue` constitutes verification. (Under the deferred Path 2 this would be a verification-key DID URL.)" }
            },
            "proofValue": {
              "@id": "pac-aspect:proofValue",
              "@type": "schema:string",
              "@context": { "@definition": "Mandatory under indexer-trust: the `provePredicate` TRANSACTION HASH, verified via the Midnight indexer. (Under the deferred Path 2 this would be the encoded ZK proof bytes.)" }
            }
          }
        },
        "status": {
          "@id": "aac-aspect:status",
          "@type": "schema:string",
          "@context": {
            "@definition": "Optional: attribute status, e.g. `predicate-proven`."
          }
        }
      }
    },
    "origin": {
      "@id": "aac-aspect:origin",
      "@context": {
        "@version": 1.1,
        "@definition": "Optional: provenance of the attested data (DID, SHA3-512 checksum, semanticId). Reused unchanged from AAC.",
        "id": "@id",
        "type": "@type",
        "digestMultibase": {
          "@id": "aac-aspect:digestMultibase",
          "@type": "schema:string"
        },
        "semanticId": {
          "@id": "aac-aspect:semanticId",
          "@type": "@id"
        }
      }
    }
  }
}
